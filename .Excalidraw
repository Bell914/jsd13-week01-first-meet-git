    {
      "id": "Hm1BY4ScVEHJefqLkEhZX",
      "type": "text",
      "x": 3191.545522728591,
      "y": -889.4065441241414,
      "width": 535.0004272460938,
      "height": 104.19998168945327,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a9",
      "roundness": null,
      "seed": 1548683647,
      "version": 400,
      "versionNonce": 571065397,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783310828601,
      "link": null,
      "locked": false,
      "text": "Computer = รถยนต์ส่วนตัวของคุณ\n\nInternet = ถนนทางหลวงที่เชื่อมต่อทุกที่เข้าด้วยกัน\n\nWeb Apps = ห้างสรรพสินค้าหรือร้านอาหารปลายทางที่คุณต้องการไปใช้บริการ",
      "fontSize": 16.67199707031252,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Computer = รถยนต์ส่วนตัวของคุณ\n\nInternet = ถนนทางหลวงที่เชื่อมต่อทุกที่เข้าด้วยกัน\n\nWeb Apps = ห้างสรรพสินค้าหรือร้านอาหารปลายทางที่คุณต้องการไปใช้บริการ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9o28sHV7Zc9oBZ5DEjNYu",
      "type": "text",
      "x": 1103.8779011772974,
      "y": -354.5893412924389,
      "width": 1287.125821705164,
      "height": 127.19313758616192,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ae",
      "roundness": null,
      "seed": 164365467,
      "version": 392,
      "versionNonce": 23735477,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783310429860,
      "link": null,
      "locked": false,
      "text": "Frontend (React): renders the UI in the browser and sends HTTP requests\n(GET, POST, etc.) to the backend, then updates the screen when a response\ncomes back.",
      "fontSize": 33.91817002297651,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Frontend (React): renders the UI in the browser and sends HTTP requests (GET, POST, etc.) to the backend, then updates the screen when a response comes back.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "sWv0WS40geumEkdrT0lQh",
      "type": "text",
      "x": 1108.8533112850973,
      "y": -184.31308443713738,
      "width": 1324.1982531878275,
      "height": 127.19313758616192,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 1280861845,
      "version": 275,
      "versionNonce": 1565314581,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783310429860,
      "link": null,
      "locked": false,
      "text": "Backend (Node.js + Express): sits in the middle, handling routing, validation, and\nbusiness logic (ตรรกะหลังบ้าน). It receives requests, decides what to do, and\nqueries the database when needed.",
      "fontSize": 33.91817002297651,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Backend (Node.js + Express): sits in the middle, handling routing, validation, and business logic (ตรรกะหลังบ้าน). It receives requests, decides what to do, and queries the database when needed.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "dSnZ9P6iaVzYZ39YNm99G",
      "type": "text",
      "x": 1114.1422479592372,
      "y": -16.349696821699126,
      "width": 1297.9458297333372,
      "height": 84.79542505744128,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ag",
      "roundness": null,
      "seed": 280410427,
      "version": 438,
      "versionNonce": 1528054645,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783310429860,
      "link": null,
      "locked": false,
      "text": "Database (MongoDB): stores and retrieves data as documents (JSON/BSON),\nsending results back to the backend to be shaped into an HTTP response.",
      "fontSize": 33.91817002297651,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Database (MongoDB): stores and retrieves data as documents (JSON/BSON), sending results back to the backend to be shaped into an HTTP response.",
      "autoResize": false,
      "lineHeight": 1.25
    },
